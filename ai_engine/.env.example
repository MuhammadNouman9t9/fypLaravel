# Copy to ai_engine/.env and fill in values.
# Used only by the FastAPI AI engine (port 8001).

# Required for POST /ai/chat (Anthropic Claude)
ANTHROPIC_API_KEY=

# Optional override (default: claude-sonnet-4-20250514)
# Tip (cheap/lightweight): use a Haiku model to reduce cost.
# Examples (pick ONE that exists on your Anthropic account):
# ANTHROPIC_MODEL=claude-3-5-haiku-latest
# ANTHROPIC_MODEL=claude-3-haiku-20240307
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Alternative: Groq (often cheaper / generous free tier) ---
# Set AI_PROVIDER=groq to use Groq for /ai/chat instead of Anthropic.
# AI_PROVIDER=groq
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant
